#!/bin/bash

# Script centralizado para ejecutar herramientas y utilidades
#
# Instalación:
#   1. Copiar o crear enlace simbólico: ln -s /Users/josepgarcia/Developer/Tools/tools ~/bin/tools
#   2. Dar permisos de ejecución: chmod +x ~/bin/tools
#   3. Añadir ~/bin al PATH (si no está): echo 'export PATH="$HOME/bin:$PATH"' >> ~/.zshrc
#   4. Recargar configuración: source ~/.zshrc
#
# Uso: tools <comando> [opciones]

# Resolve the source to handle symlinks
SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do # resolve $SOURCE until the file is no longer a symlink
  DIR="$( cd -P "$( dirname "$SOURCE" )" >/dev/null 2>&1 && pwd )"
  SOURCE="$(readlink "$SOURCE")"
  [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE" # if $SOURCE was a relative symlink, we need to resolve it relative to the path where the symlink file was located
done
TOOLS_DIR="$( cd -P "$( dirname "$SOURCE" )" >/dev/null 2>&1 && pwd )"

# Colores
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
RED='\033[0;31m'
NC='\033[0m' # No Color

show_help() {
    echo -e "${YELLOW}Tools Manager${NC}"
    echo ""
    echo -e "${BLUE}USO:${NC}"
    echo "    tools <comando> [opciones]"
    echo ""
    echo -e "${BLUE}Comandos de Gestión:${NC}"
    echo -e "  ${GREEN}update${NC}               Actualizar todas las herramientas y submódulos"
    echo ""
    echo -e "${BLUE}Comandos de Seguridad:${NC}"
    echo -e "  ${GREEN}whatweb${NC}              Identificar tecnologías web"
    echo -e "  ${GREEN}domain-analyzer${NC}      Analizar dominios"
    echo -e "  ${GREEN}php-scanner${NC}          Escanear malware PHP"
    echo -e "  ${GREEN}wpprobe${NC}              Escanear plugins y vulns WordPress"
    echo -e "  ${GREEN}aigpt-wef${NC}            WordPress Exploitation Framework"
    echo ""
    echo -e "${BLUE}Comandos de WordPress:${NC}"
    echo -e "  ${GREEN}wp-create${NC}            Crear nueva instalación de WordPress"
    echo -e "  ${GREEN}wp-delete${NC}            Eliminar instalación de WordPress"
    echo -e "  ${GREEN}wp-setup-env${NC}         Configurar entorno (carpeta + BD)"
    echo -e "  ${GREEN}wp-plugin-create${NC}     Crear estructura de nuevo plugin"
    echo -e "  ${GREEN}wp-reset-admin${NC}       Resetear usuario admin (ejecutar en carpeta WP)"
    echo -e "  ${GREEN}wp-db-backup${NC}         Respaldar BD WordPress actual"
    echo -e "  ${GREEN}wp-db-restore${NC}        Restaurar BD WordPress actual"
    echo -e "  ${GREEN}wp-optimize${NC}          Optimizar base de datos WordPress"
    echo ""
    echo -e "${BLUE}Comandos Web / Auditoría:${NC}"
    echo -e "  ${GREEN}lighthouse${NC}           Ejecutar auditoría de Lighthouse"
    echo -e "  ${GREEN}mixed-content${NC}        Detectar contenido mixto (HTTP)"
    echo -e "  ${GREEN}link-checker${NC}         Detectar enlaces rotos (404)"
    echo ""
    echo -e "${BLUE}Comandos de Backup:${NC}"
    echo -e "  ${GREEN}mysql-backup${NC}         Respaldar base de datos MySQL"
    echo ""
    echo -e "${BLUE}Utilidades:${NC}"
    echo -e "  ${GREEN}nmap${NC}                 Ejecutar script de nmap"
    echo -e "  ${GREEN}resize-images${NC}        Redimensionar imágenes"
    echo -e "  ${GREEN}resize-images-cli${NC}    Redimensionar imágenes CLI (rápido)"
}

update_tools() {
    echo "🔄 Actualizando herramientas..."
    echo ""

    cd "$TOOLS_DIR" || exit 1

    # Actualizar repositorio principal
    echo "📦 Actualizando repositorio principal..."
    git pull origin main 2>/dev/null || git pull origin master 2>/dev/null || git pull
    echo ""

    # Actualizar submódulos
    echo "🔧 Actualizando submódulos..."
    git submodule update --init --recursive
    git submodule update --remote --merge
    echo ""

    # Actualizar WhatWeb (si tiene Gemfile)
    if [ -f "$TOOLS_DIR/WhatWeb/Gemfile" ]; then
        echo "💎 Actualizando WhatWeb (Ruby gems)..."
        cd "$TOOLS_DIR/WhatWeb"
        export PATH="/opt/homebrew/opt/ruby/bin:$PATH"
        bundle install 2>/dev/null || echo "⚠️  Bundle no instalado, saltando..."
        cd "$TOOLS_DIR"
        echo ""
    fi

    # Actualizar WPProbe (Go binary)
    if [ -f "$TOOLS_DIR/wpprobe/go.mod" ]; then
        echo "🔍 Actualizando WPProbe (Go)..."
        cd "$TOOLS_DIR/wpprobe"
        export PATH="/opt/homebrew/bin:$PATH"
        git pull origin main 2>/dev/null || git pull origin master 2>/dev/null || true
        go build -o wpprobe .
        ./wpprobe update-db 2>/dev/null || true
        cd "$TOOLS_DIR"
        echo ""
    fi

    # Actualizar AiGPT-WEF (dependencias Python)
    if [ -f "$TOOLS_DIR/AiGPT-WordPress-Exploitation-Framework/aigptWEF.py" ]; then
        echo "🧠 Actualizando AiGPT-WEF (Python deps)..."
        pip3 install requests --quiet 2>/dev/null || true
        echo ""
    fi

    # Actualizar domain_analyzer (si tiene requirements.txt)
    if [ -f "$TOOLS_DIR/domain_analyzer/requirements.txt" ]; then
        echo "🐍 Actualizando domain_analyzer (Python packages)..."
        pip3 install -r "$TOOLS_DIR/domain_analyzer/requirements.txt" --upgrade --quiet 2>/dev/null || \
        echo "⚠️  No se pudieron actualizar las dependencias de Python"
        echo ""
    fi

    # Actualizar PHP-Antimalware-Scanner (si tiene composer.json)
    if [ -f "$TOOLS_DIR/PHP-Antimalware-Scanner/composer.json" ]; then
        echo "🐘 Actualizando PHP-Antimalware-Scanner (Composer)..."
        cd "$TOOLS_DIR/PHP-Antimalware-Scanner"
        composer install 2>/dev/null || echo "⚠️  Composer no instalado o instalación fallida, saltando..."
        cd "$TOOLS_DIR"
        echo ""
    fi

    echo "✅ Actualización completada!"
    echo ""
    echo "📊 Estado de los submódulos:"
    git submodule status
}

show_menu() {
    clear
    echo -e "${BLUE}================================================${NC}"
    echo -e "${BLUE}Tools Manager - Interactive Menú${NC}"
    echo -e "${BLUE}================================================${NC}"
    echo -e "${YELLOW}WordPress:${NC}"
    echo -e "  ${GREEN}1)${NC} Create new WordPress site (wp-create)"
    echo -e "  ${GREEN}2)${NC} Delete WordPress site (wp-delete)"
    echo -e "  ${GREEN}3)${NC} [DUPLICATOR] Setup Environment (wp-setup-env)"
    echo -e "  ${GREEN}4)${NC} Create Plugin (wp-plugin-create)"
    echo -e "  ${GREEN}5)${NC} Reset Admin User (wp-reset-admin)"
    echo -e "  ${GREEN}6)${NC} DB Backup (wp-db-backup)"
    echo -e "  ${GREEN}7)${NC} DB Restore (wp-db-restore)"
    echo -e "  ${GREEN}8)${NC} Optimize DB (wp-optimize)"
    echo -e "${YELLOW}Auditoría Web:${NC}"
    echo -e "  ${GREEN}20)${NC} Lighthouse Audit (lighthouse)"
    echo -e "  ${GREEN}21)${NC} Mixed Content Scan (mixed-content)"
    echo -e "  ${GREEN}22)${NC} Link Checker (link-checker)"
    echo -e "${YELLOW}Otros:${NC}"
    echo -e "  ${GREEN}10)${NC} Update tools"
    echo -e "  ${GREEN}11)${NC} WhatWeb Scan"
    echo -e "  ${GREEN}12)${NC} Domain Analyzer"
    echo -e "  ${GREEN}13)${NC} PHP Malware Scanner"
    echo -e "  ${GREEN}14)${NC} MySQL Backup"
    echo -e "  ${GREEN}15)${NC} Nmap Scan"
    echo -e "  ${GREEN}16)${NC} Resize Images"
    echo -e "  ${GREEN}17)${NC} Resize Images CLI"
    echo -e "  ${GREEN}18)${NC} WPProbe Scan"
    echo -e "  ${GREEN}19)${NC} AiGPT WEF"
    echo -e "  ${RED}q)${NC} Quit"
    echo ""
    read -p "Select an option: " choice
    echo ""

    case $choice in
        1)
            read -p "Project Name: " project_name
            if [ -n "$project_name" ]; then
                "$0" wp-create "$project_name"
            else
                echo -e "${YELLOW}Cancelled: No project name provided${NC}"
            fi
            ;;
        2)
            read -p "Project Name (to delete): " project_name
            if [ -n "$project_name" ]; then
                "$0" wp-delete "$project_name"
            else
                echo -e "${YELLOW}Cancelled: No project name provided${NC}"
            fi
            ;;
        3)
            read -p "Project Name: " project_name
            if [ -n "$project_name" ]; then
                "$0" wp-setup-env "$project_name"
            else
                echo -e "${YELLOW}Cancelled: No project name provided${NC}"
            fi
            ;;
        4)
            read -p "Plugin Name: " plugin_name
            if [ -n "$plugin_name" ]; then
                "$0" wp-plugin-create "$plugin_name"
            else
                echo -e "${YELLOW}Cancelled: No plugin name provided${NC}"
            fi
            ;;
        5)
             read -p "User ID to reset [Default: 1]: " user_id
             if [ -z "$user_id" ]; then
                user_id=1
             fi
             "$0" wp-reset-admin "$user_id"
             ;;
        6)
            read -p "Optional Comment (for filename): " comment
            "$0" wp-db-backup "$comment"
            ;;
        7)
            "$0" wp-db-restore
            ;;
        8)
            "$0" wp-optimize
            ;;
        20)
            read -p "URL to Audit (or file): " target
            if [ -n "$target" ]; then
                "$0" lighthouse "$target"
            fi
            ;;
        21)
            read -p "URL to Scan: " target
            if [ -n "$target" ]; then
                "$0" mixed-content "$target"
            fi
            ;;
        22)
            read -p "URL to Scan: " target
            if [ -n "$target" ]; then
                "$0" link-checker "$target"
            fi
            ;;
        10)
            "$0" update
            ;;
        11)
            read -p "Target URL: " target
            if [ -n "$target" ]; then
                "$0" whatweb "$target"
            fi
            ;;
        12)
             read -p "Domain: " domain
            if [ -n "$domain" ]; then
                "$0" domain-analyzer -d "$domain"
            fi
            ;;
        13)
            read -p "Path to scan: " scan_path
            if [ -n "$scan_path" ]; then
                "$0" php-scanner "$scan_path"
            fi
            ;;
        14)
            "$0" mysql-backup
            ;;
        15)
            "$0" nmap
            ;;
        16)
            "$0" resize-images
            ;;
        17)
            "$0" resize-images-cli
            ;;
        18)
            read -p "Target URL: " target
            if [ -n "$target" ]; then
                "$0" wpprobe scan --url "$target"
            fi
            ;;
        19)
            read -p "Targets file: " targets_file
            if [ -n "$targets_file" ]; then
                "$0" aigpt-wef --targets "$targets_file"
            fi
            ;;
        q|Q)
            echo "Bye!"
            exit 0
            ;;
        *)
            echo "Invalid option"
            ;;
    esac
}

if [ "$#" -eq 0 ]; then
    show_menu
    exit 0
fi

case "$1" in
    # Interactive Menu
    menu)
        show_menu
        ;;

    # Gestión
    update)
        update_tools
        ;;

    # Herramientas de seguridad
    whatweb)
        shift
        cd "$TOOLS_DIR/WhatWeb"
        ./whatweb "$@"
        ;;
    domain-analyzer)
        shift
        cd "$TOOLS_DIR/domain_analyzer"
        python3 domain_analyzer.py "$@"
        ;;
    php-scanner)
        shift
        cd "$TOOLS_DIR/PHP-Antimalware-Scanner"
        if [ -x "./dist/scanner" ]; then
            ./dist/scanner "$@"
        elif [ -x "./bin/run" ]; then
            ./bin/run "$@"
        else
            echo -e "${RED}ERROR: PHP-Antimalware-Scanner executable not found.${NC}"
            echo "Run 'tools update' to install/build dependencies."
            exit 1
        fi
        ;;
    wpprobe)
        shift
        cd "$TOOLS_DIR/wpprobe"
        if [ ! -f ./wpprobe ]; then
            echo -e "${YELLOW}Building wpprobe...${NC}"
            export PATH="/opt/homebrew/bin:$PATH"
            go build -o wpprobe .
        fi
        ./wpprobe "$@"
        ;;
    aigpt-wef)
        shift
        cd "$TOOLS_DIR/AiGPT-WordPress-Exploitation-Framework"
        python3 aigptWEF.py "$@"
        ;;

    # WordPress
    wp-create)
        shift
        "$TOOLS_DIR/scripts/WordPress/wp-create.sh" "$@"
        ;;
    wp-delete)
        shift
        "$TOOLS_DIR/scripts/WordPress/wp-delete.sh" "$@"
        ;;
    wp-setup-env)
        shift
        "$TOOLS_DIR/scripts/WordPress/wp-setup-env.sh" "$@"
        ;;
    wp-plugin-create)
        shift
        "$TOOLS_DIR/scripts/WordPress/wp-plugin-create.sh" "$@"
        ;;
    wp-reset-admin)
        shift
        "$TOOLS_DIR/scripts/WordPress/wp-reset-admin.sh" "$@"
        ;;
    wp-db-backup)
        shift
        "$TOOLS_DIR/scripts/WordPress/wp-db-backup.sh" "$@"
        ;;
    wp-db-restore)
        shift
        "$TOOLS_DIR/scripts/WordPress/wp-db-restore.sh" "$@"
        ;;
    wp-optimize)
        shift
        "$TOOLS_DIR/scripts/WordPress/wp-optimize.sh" "$@"
        ;;
    lighthouse)
        shift
        "$TOOLS_DIR/scripts/WordPress/wp-lighthouse.sh" "$@"
        ;;
    mixed-content)
        shift
        "$TOOLS_DIR/scripts/WordPress/wp-mixed-content.sh" "$@"
        ;;
    link-checker)
        shift
        "$TOOLS_DIR/scripts/WordPress/wp-link-checker.sh" "$@"
        ;;

    # Backup
    mysql-backup)
        shift
        "$TOOLS_DIR/scripts/utilities/mysql_backup.sh" "$@"
        ;;

    # Utilidades
    nmap)
        shift
        "$TOOLS_DIR/scripts/utilities/nmap.sh" "$@"
        ;;
    resize-images)
        shift
        "$TOOLS_DIR/scripts/utilities/redimensionar_imagenes.sh" "$@"
        ;;
    resize-images-cli)
        shift
        "$TOOLS_DIR/scripts/utilities/redimensionar_imagenes_cli.sh" "$@"
        ;;

    -h|--help|help)
        show_help
        ;;

    *)
        show_help
        exit 1
        ;;
esac
